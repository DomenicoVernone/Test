# .env.example — root
# Variabili specifiche del server di deployment.
# Copiare in .env e compilare prima di avviare docker compose up.

# UUID della MIG instance GPU.
# Lasciare vuoto su GPU normali — il sistema usa 'all' come default.
# Compilare solo su server con GPU partizionata in MIG instances.
MIG_DEVICE=

# Path host del volume condiviso. Richiesto su Linux per il pattern DooD.
# Esempio: /var/lib/docker/volumes/clinical_twin_shared_data/_data
# Su Docker Desktop (Windows/Mac) lasciare vuoto.
HOST_SHARED_VOLUME_DIR=