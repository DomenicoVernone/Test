# .env.example — frontend
# Copia questo file in .env e compila i valori prima di avviare il frontend.
# In sviluppo locale i valori di default puntano a localhost.
# In produzione sostituire con gli URL reali raggiungibili dal browser.

VITE_AUTH_URL=http://localhost:8000
VITE_ORCHESTRATOR_URL=http://localhost:8001
VITE_LLM_URL=http://localhost:8002