# .env.example — model_service
# Copia questo file in .env e compila i valori prima di avviare il servizio.

SHARED_VOLUME_DIR=/shared_data
R_ENGINE_URL=http://inference_engine:8000/infer

MLFLOW_TRACKING_URI=https://dagshub.com/<REPO_OWNER>/<REPO_NAME>.mlflow
MLFLOW_TRACKING_USERNAME=<DAGSHUB_USERNAME>
MLFLOW_TRACKING_PASSWORD=<DAGSHUB_TOKEN>

DAGSHUB_USERNAME=<DAGSHUB_USERNAME>
DAGSHUB_TOKEN=<DAGSHUB_TOKEN>

REPO_OWNER=<REPO_OWNER>
REPO_NAME=<REPO_NAME>