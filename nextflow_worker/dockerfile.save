# ==========================================
# FILE: nextflow_worker/Dockerfile
# OBIETTIVO: Fat Container con FreeSurfer 7.2, FSL, Nextflow e PyRadiomics
# ==========================================

# 1. BASE: Il Freesurfer ESATTO usato nel training (basato su CentOS 8)
FROM freesurfer/freesurfer:7.2.0

USER root

# FIX CRITICO: CentOS 8 è EOL. Ripristiniamo i mirror usando Vault.
RUN cd /etc/yum.repos.d/ && \
    sed -i 's/mirrorlist/#mirrorlist/g' CentOS-* && \
    sed -i 's|#baseurl=http://mirror.centos.org|baseurl=http://vault.centos.org|g' CentOS-* || true

# 2. Dipendenze di sistema (incluso Python 3 di sistema per installare FSL)
RUN yum update -y && \
    yum install -y java-11-openjdk-headless wget curl unzip file bzip2 gcc gcc-c++ make mesa-libGL python3 && \
    yum clean all

# ==========================================
# 3. INTEGRAZIONE FSL (FMRIB Software Library)
# ==========================================
# Scarichiamo ed eseguiamo l'installer ufficiale in modalità silenziosa (-q)
RUN curl -sSLO https://fsl.fmrib.ox.ac.uk/fsldownloads/fslinstaller.py && \
    python3 fslinstaller.py -d /usr/local/fsl -q && \
    rm fslinstaller.py

# Setup Variabili d'Ambiente FSL (simili a quelle del tuo fsl.dockerfile)
ENV FSLDIR=/usr/local/fsl
ENV PATH=$PATH:$FSLDIR/bin
ENV FSLOUTPUTTYPE=NIFTI_GZ
ENV FSLMULTIFILEQUIT=TRUE
# ==========================================




# 4. Nextflow (Orchestratore interno)
RUN curl -s https://get.nextflow.io | bash && \
    mv nextflow /usr/local/bin/ && \
    chmod +x /usr/local/bin/nextflow

# 5. Miniconda e PyRadiomics (Replica ESATTA del tuo pyradiomics.dockerfile)
RUN wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh -O miniconda.sh && \
    bash miniconda.sh -b -p /opt/conda && \
    rm miniconda.sh

ENV PATH="/opt/conda/bin:${PATH}"

RUN conda install -y python=3.12 && \
    pip install --upgrade pip setuptools wheel && \
    wget https://github.com/AIM-Harvard/pyradiomics/archive/refs/heads/master.zip && \
    unzip master.zip && \
    cd pyradiomics-master && \
    python -m pip install . && \
    cd .. && \
    rm -rf pyradiomics-master master.zip

# 6. Librerie per il microservizio FastAPI (Clinical Twin Backend)
RUN pip install --no-cache-dir fastapi uvicorn pydantic httpx

# 7. Licenza Freesurfer
# Ricordati di mettere license.txt nella cartella nextflow_worker!
COPY license.txt /usr/local/freesurfer/.license

# 8. Setup directory app
WORKDIR /app
COPY . /app

EXPOSE 8002

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8002"]
