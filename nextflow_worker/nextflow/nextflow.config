// File: nextflow_worker/nextflow/nextflow.config
//
// Configurazione Nextflow per la pipeline Clinical Twin.
// I parametri qui definiti sono i default di produzione e sovrascrivono
// quelli eventualmente presenti in preprocessing.nf.
//
// Variabili d'ambiente lette a runtime:
//   NF_OUTDIR    — directory di output nel volume condiviso
//   NF_LABELS    — path del file ROI_labels.tsv
//   NF_SETTINGS  — path del file pyradiomics.yaml
//   MIG_DEVICE   — UUID della MIG instance GPU (specifico del server)
//                  Se non impostata, usa 'all' (GPU normali)

docker {
    enabled      = true
    fixOwnership = true
    // runOptions monta la licenza FreeSurfer in /tmp/freesurfer_license.txt,
    // path atteso dal processo nifti_converter via ENV FS_LICENSE.
    // Il file viene copiato li' da main.py prima di avviare la pipeline.
    runOptions = '-v /tmp:/tmp -v /tmp/freesurfer_license.txt:/app/license.txt'
}

process {
    withName: 'fastsurfer' {
        container = 'deepmi/fastsurfer:cuda-v2.4.2'
        // MIG_DEVICE: UUID della MIG instance sul server di deployment.
        // Esternalizzato per evitare dipendenze hard-coded dall'hardware specifico.
        // Su GPU normali lasciare MIG_DEVICE vuoto — il fallback 'all' e' corretto.
        containerOptions = "--gpus \"device=${System.getenv('MIG_DEVICE') ?: 'all'}\" --user \$(id -u):\$(id -g) --entrypoint \"\""
    }
    withName: 'freesurfer' {
        container = 'clinical-freesurfer'
    }
    withName: 'nifti_converter' {
        container = 'clinical-freesurfer'
    }
    withName: 'roi_creator' {
        container = 'clinical-fsl'
    }
    withName: 'csv_collector' {
        container        = 'clinical-pyradiomics'
        containerOptions = '-v clinical_twin_shared_data:/shared_data'
    }
    withName: 'feature_extraction' {
        container        = 'clinical-pyradiomics'
        stageInMode      = 'copy'
        containerOptions = '-v clinical_twin_shared_data:/shared_data'
    }
}

workDir = '/tmp/nextflow_work'

params.outdir                  = System.getenv("NF_OUTDIR") ?: "/shared_data/nf_output"
params.segmenter_folder_output = "${params.outdir}/segmentation"
params.features_output         = "${params.outdir}/features"
params.error_strategy          = 'ignore'
params.maxforks = 4
params.pyradiomics_jobs = 8
params.brain_segmenter = "fastsurfer"

params.labels   = System.getenv("NF_LABELS")   ?: "/app/data/external/ROI_labels.tsv"
params.settings = System.getenv("NF_SETTINGS") ?: "/app/nextflow/configs/pyradiomics.yaml"
params.license  = "/app/license.txt"

params.fastsurfer_threads = 4
params.fastsurfer_device  = "cuda"
params.fastsurfer_3T      = false
