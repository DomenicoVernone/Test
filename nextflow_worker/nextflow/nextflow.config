// File: nextflow_worker/nextflow/nextflow.config
//
// Configurazione Nextflow per la pipeline Clinical Twin.
//
// Variabili d'ambiente supportate:
//
//   NF_OUTDIR   → directory output condivisa
//   NF_LABELS   → path ROI_labels.tsv
//   NF_SETTINGS → path pyradiomics.yaml
//   MIG_DEVICE  → UUID MIG GPU (server production)
//
// Se MIG_DEVICE non è impostata → usa tutte le GPU disponibili


docker {

    enabled      = true
    fixOwnership = true

    /*
     Mount globali necessari alla pipeline:

     - /tmp → scratch FreeSurfer
     - freesurfer license
     - shared volume per output pipeline
    */

    runOptions = '''
        -v /tmp:/tmp
        -v /tmp/freesurfer_license.txt:/app/license.txt
        -v clinical_twin_shared_data:/shared_data
    '''
}


process {

    /*
     FASTSURFER (GPU)
    */

    withName: 'fastsurfer' {

        container = 'deepmi/fastsurfer:cuda-v2.4.2'

        containerOptions = """
            --gpus device=${System.getenv('MIG_DEVICE') ?: 'all'}
            --user \$(id -u):\$(id -g)
            --entrypoint ""
        """
    }


    /*
     FREESURFER (CPU)
    */

    withName: 'freesurfer' {
        container = 'clinical-freesurfer'
    }


    /*
     MGZ → NIFTI
    */

    withName: 'nifti_converter' {
        container = 'clinical-freesurfer'
    }


    /*
     ROI CREATION
    */

    withName: 'roi_creator' {
        container = 'clinical-fsl'
    }


    /*
     CSV CREATION (Radiomics input)
    */

    withName: 'csv_collector' {

        container = 'clinical-pyradiomics'

        containerOptions =
            '-v clinical_twin_shared_data:/shared_data'
    }


    /*
     FEATURE EXTRACTION (PyRadiomics)
    */

    withName: 'feature_extraction' {

        container = 'clinical-pyradiomics'

        stageInMode = 'copy'

        containerOptions =
            '-v clinical_twin_shared_data:/shared_data'
    }
}


/*
 WORK DIRECTORY (cache Nextflow)
*/

workDir = '/tmp/nextflow_work'


/*
 OUTPUT DIRECTORY
*/

params.outdir =
    System.getenv("NF_OUTDIR")
    ?: "/shared_data/nf_output"


params.segmenter_folder_output =
    "${params.outdir}/segmentation"


params.features_output =
    "${params.outdir}/features"


/*
 PIPELINE CONTROL FLAGS
*/

params.error_strategy   = 'terminate'
params.maxforks         = 4
params.pyradiomics_jobs = 8


/*
 SEGMENTATION ENGINE DEFAULT
*/

params.brain_segmenter = "fastsurfer"


/*
 INPUT FILES
*/

params.labels =
    System.getenv("NF_LABELS")
    ?: "/app/data/external/ROI_labels.tsv"


params.settings =
    System.getenv("NF_SETTINGS")
    ?: "/app/nextflow/configs/pyradiomics.yaml"


params.license =
    "/app/license.txt"


/*
 FASTSURFER SETTINGS
*/

params.fastsurfer_threads = 4
params.fastsurfer_device  = "cuda"
params.fastsurfer_3T      = false